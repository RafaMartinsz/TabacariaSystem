@model IEnumerable<Venda>

@{
    ViewData["Title"] = "Index";
}

<h1>Vendas</h1>
<p>
<a asp-action="Create"
   class="btn btn-success">
    Nova Venda
</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ClienteId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProdutoId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Quantidade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ValorTotal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataVenda)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                    @item.Cliente?.Nome
                </td>
            <td>
                    @item.Produto?.Nome
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantidade)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ValorTotal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataVenda)
            </td>
            <td>
              <a asp-action="Edit"
   asp-route-id="@item.Id"
   class="btn btn-sm btn-info text-white">
    Editar
</a>

<a asp-action="Details"
   asp-route-id="@item.Id"
   class="btn btn-sm btn-primary">
    Detalhes
</a>

<a asp-action="Delete"
   asp-route-id="@item.Id"
   class="btn btn-sm btn-danger">
    Excluir
</a>
            </td>
        </tr>
}
    </tbody>
</table>
