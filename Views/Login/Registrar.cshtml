@model TabacariaSystem.Models.Usuario

@{
    ViewData["Title"] = "Cadastrar Usuário";
}

<h1 class="display-6 fw-bold mb-4">Novo Usuário</h1>

<div class="row">
    <div class="col-md-4">
        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger py-2" role="alert">
                @ViewBag.Erro
            </div>
        }

        <form asp-action="Registrar" method="post">
            <div class="form-group mb-3">
                <label for="usuario" class="form-label fw-bold text-dark small">Nome</label>
                <input type="text" name="usuario" id="usuario" class="form-control" required />
            </div>

           <div class="form-group mb-4">
             <label for="senha" class="form-label fw-bold text-dark small">Senha</label>
             <div class="input-group">
             <input type="password" name="senha" id="senha" class="form-control" required />
             <button class="btn btn-outline-secondary" type="button" id="btnMostrarSenha" onclick="toggleSenha('senha')">
            👁️
            </button>
            </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success fw-semibold px-4 me-2">Criar</button>
                <a asp-action="Usuarios" class="text-decoration-none small text-secondary">Voltar para a lista</a>
            </div>
        </form>
    </div>
</div>