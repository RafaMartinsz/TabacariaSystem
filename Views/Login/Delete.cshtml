@model TabacariaSystem.Models.Usuario

@{
    ViewData["Title"] = "Excluir Usuário";
}

<h1 class="display-6 fw-bold mb-4">Excluir</h1>

<h3 class="text-danger mb-4">Deseja excluir este usuário?</h3>

<div>
    <h4 class="fs-5 fw-bold text-dark">Usuário</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2 fw-bold text-dark">
            Nome de Usuário
        </dt>
        <dd class="col-sm-10 text-secondary">
            @Html.DisplayFor(model => model.NomeUsuario)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger fw-semibold px-3 me-2">Excluir</button>
        <a asp-action="Usuarios" class="text-decoration-none small text-secondary">Voltar para a lista</a>
    </form>
</div>