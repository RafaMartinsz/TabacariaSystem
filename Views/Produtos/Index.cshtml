@model IEnumerable<TabacariaSystem.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<h1 class="mb-4">Produtos</h1>

<!-- FORMULÁRIO DE PESQUISA -->
<form method="get" class="mb-3 d-flex">

    <!-- Campo onde o usuário digita o nome -->
    <input type="text"
           name="pesquisa"
           class="form-control me-2"
           placeholder="Pesquisar produto..." />

    <!-- Botão para enviar a pesquisa -->
    <button type="submit" class="btn btn-success">
        Buscar
    </button>

</form>

<!-- BOTÃO PARA CRIAR NOVO PRODUTO -->
<p>
    <a asp-action="Create" class="btn btn-success">
        Novo Produto
    </a>
</p>

<!-- TABELA DE PRODUTOS -->
<table class="table table-striped table-hover">

    <!-- CABEÇALHO -->
    <thead style="background-color:#d9f3ff;">
        <tr>
            <th>Nome</th>
            <th>Categoria</th>
            <th>Preço</th>
            <th>Quantidade</th>
            <th>Ações</th>
        </tr>
    </thead>

    <!-- CORPO DA TABELA -->
    <tbody>

        <!-- Percorre todos os produtos -->
        @foreach (var item in Model)
        {
            <tr>

                <!-- Nome do produto -->
                <td>
                    @item.Nome
                </td>

                <!-- Categoria -->
                <td>
                    @item.Categoria
                </td>

                <!-- Preço formatado -->
                <td>
                    R$ @item.Preco
                </td>

                <!-- Quantidade em estoque -->
                <td>

                    <!-- Se tiver pouco estoque -->
                    @if (item.Quantidade <= 5)
                    {
                        <span class="badge text-bg-danger">
                            Baixo Estoque (@item.Quantidade)
                        </span>
                    }
                    else
                    {
                        <span class="badge text-bg-success">
                            @item.Quantidade
                        </span>
                    }

                </td>

                <!-- BOTÕES -->
                <td>

                    <!-- Editar -->
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-outline-info">
                        Editar
                    </a>               

                    <!-- Excluir -->
                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-outline-danger">
                        Excluir
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>